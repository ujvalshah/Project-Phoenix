{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/article/:id", "destination": "/api/og-proxy" },
    { "source": "/collections/:id", "destination": "/api/og-proxy" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
