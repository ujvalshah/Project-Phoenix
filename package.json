{
  "name": "nuggets_v60",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:all": "concurrently --kill-others-on-fail \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build && npm run build:server",
    "build:server": "tsc -p server/tsconfig.build.json --noCheck",
    "build:verify": "npm run build && node scripts/verify-build.js && node scripts/check-bundle-budget.mjs",
    "analyze:bundle": "cross-env ANALYZE=1 vite build",
    "analyze:bundle:print": "node scripts/print-bundle-top.mjs",
    "test:bundles": "node scripts/check-bundle-budget.mjs",
    "perf:scorecard-bundle-snapshot": "node scripts/update-scorecard-bundle-snapshot.mjs",
    "perf:collect": "cross-env PERF_COLLECT_RUNS=3 playwright test --config=playwright.perf.config.ts",
    "perf:lh-mobile-local": "npx --yes lighthouse@12 http://127.0.0.1:3000/ --only-categories=performance --output=json --output-path=lighthouse-mobile-local-unthrottled.json --form-factor=mobile --screenEmulation.mobile --quiet --disable-full-page-screenshot --max-wait-for-load=90000 --throttling-method=provided --chrome-flags=\"--headless=new --no-sandbox --disable-gpu\"",
    "preview": "vite preview",
    "start": "node scripts/run-production-server.mjs",
    "start:tsx": "node --import tsx server/src/index.ts",
    "promote-admin": "tsx server/src/utils/promoteToAdmin.ts",
    "list-users": "tsx server/src/utils/listUsers.ts",
    "diagnose-users": "tsx server/src/utils/diagnoseUserIssues.ts",
    "check-email": "tsx server/src/utils/checkUserByEmail.ts",
    "fix-indexes": "tsx server/src/utils/fixUserIndexes.ts",
    "cleanup-duplicates:dry-run": "tsx server/src/utils/cleanupDuplicateUsers.ts",
    "cleanup-duplicates": "cross-env DRY_RUN=false tsx server/src/utils/cleanupDuplicateUsers.ts",
    "sanitize:dry-run": "tsx server/scripts/sanitizeDatabase.ts",
    "sanitize:execute": "cross-env DRY_RUN=false tsx server/scripts/sanitizeDatabase.ts",
    "sanitize:force": "cross-env DRY_RUN=false FORCE_EXECUTE=true tsx server/scripts/sanitizeDatabase.ts",
    "migrate-canonical-names": "tsx server/src/scripts/runMigration.ts",
    "migrate-categoryids": "tsx server/src/scripts/backfillCategoryIds.ts",
    "update-tag-usage": "tsx server/src/scripts/updateTagUsageCounts.ts",
    "remove:uncategorized": "tsx server/scripts/removeUncategorizedTag.ts",
    "audit": "node scripts/audit-code.js",
    "lint": "npm run lint:client",
    "lint:all": "npm run lint:client && npm run lint:server",
    "lint:client": "eslint src --ext .ts,.tsx --rulesdir eslint-rules",
    "lint:server": "eslint server/src/index.ts server/src/config server/src/routes server/src/controllers server/src/middleware server/src/models server/src/services server/src/utils/sentry.ts server/src/utils/metrics.ts --ext .ts --rulesdir eslint-rules --rule \"no-unsafe-direct-mutation-fetch: off\"",
    "lint:fix": "npm run lint:fix:client && npm run lint:fix:server",
    "lint:fix:client": "eslint src --ext .ts,.tsx --fix --rulesdir eslint-rules",
    "lint:fix:server": "eslint server/src/index.ts server/src/config server/src/routes server/src/controllers server/src/middleware server/src/models server/src/services server/src/utils/sentry.ts server/src/utils/metrics.ts --ext .ts --fix --rulesdir eslint-rules --rule \"no-unsafe-direct-mutation-fetch: off\"",
    "test:eslint-rules": "node eslint-rules/tests/no-unsafe-direct-mutation-fetch.test.cjs",
    "test": "vitest run",
    "test:perf-guards": "vitest run src/utils/__tests__/performanceRollout.test.ts src/utils/__tests__/nuggetComposerV2Rollout.test.ts src/utils/__tests__/markdownSlimFeedIsolation.test.ts src/components/__tests__/createNuggetModalChunkCache.test.ts src/components/modals/__tests__/shellDraft.test.ts",
    "test:ci": "vitest run",
    "test:e2e:smoke": "cross-env PLAYWRIGHT_SKIP_GLOBAL_AUTH=0 playwright test tests/e2e/perf-guards-nugget-modal.spec.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "icons:generate": "node scripts/generate-brand-icons.mjs",
    "typecheck": "npm run typecheck:client",
    "typecheck:all": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.ci.json --noEmit",
    "prepare": "husky || node -e \"process.exit(0)\""
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@sentry/node": "^10.32.1",
    "@sentry/react": "^10.32.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-virtual": "^3.13.13",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "cloudinary": "^2.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.556.0",
    "mongoose": "^9.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.0",
    "open-graph-scraper": "^6.11.0",
    "pino": "^10.1.0",
    "probe-image-size": "^7.2.3",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "redis": "^5.10.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.7.0",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.7.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vercel/node": "^5.6.22",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.4.0",
    "mongodb": "^7.2.0",
    "mongodb-memory-server": "^11.1.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^7.2.7",
    "vitest": "^2.1.0",
    "web-vitals": "^5.2.0"
  }
}
