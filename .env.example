ENABLE_EMAIL_VERIFICATION=false
# ============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains secrets
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED - Server will fail to start without these
# ----------------------------------------------------------------------------

# MongoDB Connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Or: mongodb://localhost:27017/database (for local MongoDB)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# JWT Secret for token signing and verification
# MUST be at least 32 characters long for security
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_long

# Node Environment
# Options: development | production | test
# Production requires FRONTEND_URL, RESEND_API_KEY, and EMAIL_FROM (see below)
NODE_ENV=development

# ----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION - Server will fail to start in production without these
# ----------------------------------------------------------------------------

# Frontend URL (your live site, e.g. https://yourdomain.com)
# Used for: CORS (always included in allowlist) and links in verification / password-reset emails
FRONTEND_URL=https://yourdomain.com

# Extra browser origins allowed to call the API (comma-separated, no spaces after commas is fine)
# Add staging or Vercel preview URLs here, e.g. https://myapp-git-branch.vercel.app,https://staging.example.com
# FRONTEND_URL is added automatically; you do not need to repeat it here.
CORS_ALLOWED_ORIGINS=

# Resend API key (required in production so signup verification and password reset emails work)
RESEND_API_KEY=your_resend_api_key_here

# Verified sender in Resend, e.g. "Nuggets <noreply@yourdomain.com>" (required in production)
EMAIL_FROM=Your App <noreply@yourdomain.com>

# ----------------------------------------------------------------------------
# OPTIONAL - Server will use defaults if not provided
# ----------------------------------------------------------------------------

# Server Port
# Default: 5000
PORT=5000

# ----------------------------------------------------------------------------
# OPTIONAL - Feature-specific configuration
# ----------------------------------------------------------------------------

# Google Gemini API Key (for AI features)
# Optional - AI features will be disabled if not provided
API_KEY=your_gemini_api_key_here

# Alternative Gemini API Key environment variable names (supported)
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here
# GEMINI_KEYS=your_gemini_api_key_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name


# Microlink API Configuration (for URL unfurling)
# Enable Microlink integration (default: false)
MICROLINK_ENABLED=false

# Microlink API Key (required if MICROLINK_ENABLED=true)
MICROLINK_API_KEY=your_microlink_api_key_here

# Microlink Admin Only (default: true)
# If true, only admin users can use Microlink
# If false, all authenticated users can use Microlink
MICROLINK_ADMIN_ONLY=true

# Unfurl Cache Size
# Maximum number of cached unfurl results (default: 5000)
UNFURL_CACHE_SIZE=5000

# ----------------------------------------------------------------------------
# FRONTEND ENVIRONMENT VARIABLES (Vite)
# ----------------------------------------------------------------------------

# The SPA uses the REST API via `storageService` / api client configuration (local adapter removed).

# API URL (for production builds)
# Example: https://api.yourdomain.com
# In development, Vite proxy handles /api routes automatically
VITE_API_URL=https://api.yourdomain.com

# Flags below are client booleans via `import.meta.env.VITE_* === 'true'`.
# If a variable is omitted, the feature evaluates false unless your deploy platform injects it.
# Tracked `.env.production` in this repo intentionally lists only API/site URLs and home virtualization.
#
# Deploy checklist: staging and production must set each deployed boolean explicitly where used.
# Do not infer live values from this example file alone.

# Market Pulse Feature Toggle
# When 'true', enables Market Pulse chrome (nav, bottom tab, editor stream picker) and `?stream=pulse` URLs.
# When 'false' or absent, client forces the standard feed only — `stream=pulse` in the URL is ignored and stripped from the address bar once filters sync.
# Set per environment in your hosting UI (staging vs production values may differ).
VITE_FEATURE_MARKET_PULSE=false

# Home critical-path slimming prototype (default off)
# Master gate: enable only for controlled perf cohorts.
VITE_HOME_CRITICAL_PATH_SLIM_V1=true
# Phase A minimal above-the-fold card surface before full feed mount.
VITE_HOME_CRITICAL_PATH_SLIM_V1_PHASE_A_SURFACE=true
# Defer non-critical home queries (taxonomy, anonymous micro-header copy).
VITE_HOME_CRITICAL_PATH_SLIM_V1_DEFER_SECONDARY_HOME_QUERIES=false
# Defer non-critical home effects/context updates until Phase B.
VITE_HOME_CRITICAL_PATH_SLIM_V1_DEFER_HOME_SIDE_EFFECTS=true

# ----------------------------------------------------------------------------
# DEVELOPMENT/SCRIPT VARIABLES
# ----------------------------------------------------------------------------

# Dry Run Mode (for cleanup/sanitization scripts)
# Set to 'false' to actually execute operations (default: true for safety)
DRY_RUN=true

# Force Execute (for sanitization scripts)
# Set to 'true' to force execution even if dry run is enabled
FORCE_EXECUTE=false

# API Base URL (for test scripts)
# Default: http://localhost:5000
API_BASE_URL=http://localhost:5000


REDIS_URL=rediss://default:your_redis_password@your-redis-host.upstash.io:6379

# Local Redis for development (overrides REDIS_URL when set to true)
# Connects to redis://localhost:6379 (Memurai on Windows / Redis on Mac/Linux)
USE_LOCAL_REDIS=false

# Web Push Notifications (VAPID)
# Generate keys once: npx web-push generate-vapid-keys
# WARNING: Never regenerate — all existing push subscriptions become invalid
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@nuggetnews.app

# tokenVersion enforcement (PR5).
# When true, JWTs whose embedded tokenVersion differs from the user's current
# tokenVersion are rejected with 401 SESSION_REVOKED. Bumping tokenVersion
# (on role/email/password change, suspend/ban/delete, admin revoke-sessions)
# then immediately invalidates every live access token for that user.
# Production default: true when this value is unset (enforced in envValidation).
# Development/test default: false (observe-only). Set explicitly to override.
# Recommended production setting: ENFORCE_TOKEN_VERSION=true
ENFORCE_TOKEN_VERSION=








# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. All secrets (JWT_SECRET, API keys) should be strong and randomly generated
# 2. Never commit .env file to version control
# 3. In production, use environment variable injection from your hosting platform
# 4. JWT_SECRET must be at least 32 characters for security
# 5. In production, the server requires FRONTEND_URL, RESEND_API_KEY, and EMAIL_FROM
# 6. Set CORS_ALLOWED_ORIGINS if the browser origin differs from FRONTEND_URL (e.g. preview deploys)
# 7. MONGO_URI can also be set as MONGODB_URI (both are supported)



